{
  "name": "camp-fit",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:ssrf-egress": "vitest run --config vitest.ssrf.config.ts",
    "test:db:reset": "tsx scripts/test-db-reset.ts",
    "db:local:up": "docker compose -f docker-compose.postgres.yml up -d --wait",
    "db:local:down": "docker compose -f docker-compose.postgres.yml down",
    "db:local:schema": "sh scripts/local-db-schema.sh",
    "db:local:reset": "sh scripts/local-db-reset.sh",
    "db:migrate": "node-pg-migrate up --migrations-dir prisma/migrations --migrations-table pgmigrations --no-check-order",
    "db:migrate:down": "node-pg-migrate down --migrations-dir prisma/migrations --migrations-table pgmigrations --no-check-order",
    "db:migrate:new": "node-pg-migrate create --migrations-dir prisma/migrations --migration-file-language sql",
    "db:migrate:status": "tsx scripts/db-migrate-status.ts",
    "db:migrate:baseline": "tsx scripts/db-migrate-baseline.ts",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run test:ssrf-egress && npm run check:content-boundary && npm run check:decisions && npm run test:safe-url && npm run test:ingestion-runner && npm run test:content-guards && npm run test:render-fetch && npm run test:shell-detect-retry && npm run test:cutover-baseline && npm run test:discovery-replay && npm run test:traverse-replay && npm run test:recrawl-adapter && npm run test:traverse-cost-guards && npm run test:traverse-crawl && eslint .",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "check:decisions": "node scripts/check-decisions.cjs check",
    "gen:decisions-index": "node scripts/check-decisions.cjs gen-index",
    "freeze:adrs": "node scripts/freeze-adrs.mjs",
    "crawl": "tsx scripts/run-crawl.ts",
    "backfill:providers": "tsx scripts/backfill-providers.ts",
    "backfill:claim-store": "tsx scripts/backfill-claim-store.ts",
    "backfill:claim-store:dry": "tsx scripts/backfill-claim-store.ts --dry-run",
    "harvest": "tsx scripts/harvest-aggregator.ts",
    "crawl:providers": "tsx scripts/crawl-aggregator-providers.ts",
    "seed": "tsx scripts/seed.ts",
    "scrape": "tsx scripts/scrape.ts",
    "scrape:dry": "tsx scripts/scrape.ts --dry-run",
    "discover": "tsx scripts/discover.ts",
    "discover:dry": "tsx scripts/discover.ts --dry-run",
    "test:access": "tsx scripts/test-access.ts",
    "test:learning": "tsx scripts/test-review-learning-signals.ts",
    "test:safe-url": "tsx scripts/test-safe-url.ts",
    "test:ingestion-runner": "tsx scripts/test-ingestion-runner.ts",
    "test:content-guards": "tsx scripts/test-content-guards.ts",
    "test:render-fetch": "tsx scripts/test-render-fetch.ts",
    "test:shell-detect-retry": "tsx scripts/test-shell-detect-retry.ts",
    "test:surface": "tsx scripts/test-surface-trust-export.ts",
    "verify:survey-review-items": "tsx scripts/verify-survey-review-items.ts",
    "verify:survey-value-descriptor": "tsx scripts/verify-survey-value-descriptor.ts",
    "verify:survey-apply": "tsx scripts/verify-survey-apply-path.ts",
    "verify:survey-session": "tsx scripts/verify-survey-server-owned-session.ts",
    "verify:survey-browser": "playwright test tests/browser/survey-review-fixture.spec.ts tests/browser/survey-review-real-proposal.spec.ts",
    "smoke:prod": "playwright test --config=playwright.prod.config.ts",
    "verify:survey": "tsx scripts/verify-survey-integration.ts",
    "verify:admin": "tsx scripts/verify-admin-platform.ts",
    "test:traverse-replay": "tsx scripts/test-traverse-replay.ts",
    "test:discovery-replay": "tsx scripts/test-discovery-replay.ts",
    "test:recrawl-adapter": "tsx scripts/test-recrawl-adapter.ts",
    "test:d1-lookout-adapter": "node --import tsx scripts/test-d1-lookout-adapter.ts",
    "test:l4-lookout-check": "node --import tsx scripts/test-l4-lookout-check.ts",
    "test:l4-lookout-events": "node --import tsx scripts/test-l4-lookout-events.ts",
    "test:l4-lookout-discovery": "node --import tsx scripts/test-l4-lookout-discovery.ts",
    "report:l4-lookout-parity": "node --import tsx scripts/l4-lookout-parity-report.ts",
    "test:d0-identity-hydration": "node --import tsx scripts/test-d0-identity-hydration.ts",
    "report:d0-review-noise": "node --import tsx scripts/d0-review-noise-report.ts",
    "report:d1-production-replay": "TSX_DISABLE_CACHE=1 node --permission --allow-fs-read=* --allow-fs-write=\"${TMPDIR:-/tmp}/campfit-d1-legacy-*\" --allow-child-process --allow-worker --import tsx scripts/d1-production-replay.ts",
    "test:traverse-cost-guards": "tsx scripts/test-traverse-cost-guards.ts",
    "test:traverse-crawl": "tsx scripts/test-traverse-crawl.ts",
    "test:cutover-baseline": "tsx scripts/test-cutover-baseline.ts",
    "cutover:report": "tsx scripts/cutover-report.ts",
    "review:throughput": "tsx scripts/review-throughput-report.ts",
    "report:shadow": "tsx scripts/shadow-precision-report.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@kontourai/datum": "^0.3.0",
    "@kontourai/lookout": "0.2.0",
    "@kontourai/surface": "^2.3.0",
    "@kontourai/survey": "^1.13.0",
    "@kontourai/traverse": "0.14.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "postcss": "$postcss"
  }
}
