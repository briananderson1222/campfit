generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CampType {
  SUMMER_DAY
  SLEEPAWAY
  FAMILY
  VIRTUAL
  WINTER_BREAK
  SCHOOL_BREAK
}

enum CampCategory {
  SPORTS
  ARTS
  STEM
  NATURE
  ACADEMIC
  MUSIC
  THEATER
  COOKING
  MULTI_ACTIVITY
  OTHER
}

enum RegistrationStatus {
  OPEN
  FULL
  CLOSED
  WAITLIST
  COMING_SOON
  UNKNOWN
}

enum DataConfidence {
  VERIFIED
  PLACEHOLDER
  STALE
}

enum SourceType {
  CSV
  SCRAPER
  MANUAL
  PROVIDER_FORM
}

enum PricingUnit {
  PER_WEEK
  PER_SESSION
  PER_DAY
  FLAT
  PER_CAMP
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserTier {
  FREE
  PREMIUM
}

enum NotificationType {
  REGISTRATION_OPENS
  CAMP_APPROACHING
  NEW_CAMP_MATCH
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DataSourceStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum AdminEntityType {
  CAMP
  PROVIDER
  PERSON
}

enum ReviewFlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum AttestationStatus {
  ACTIVE
  STALE
  INVALIDATED
}

enum AiActionCapability {
  READ
  PROPOSE
  WRITE
}

enum AiActionStatus {
  REQUESTED
  CONFIRMED
  REJECTED
  COMPLETED
  FAILED
}

model Camp {
  id                    String             @id @default(uuid())
  slug                  String             @unique
  name                  String
  description           String             @default("")
  notes                 String?
  campType              CampType
  category              CampCategory
  campTypes             CampType[]         @default([])
  categories            CampCategory[]     @default([])
  websiteUrl            String             @default("")
  applicationUrl        String?
  contactEmail          String?
  contactPhone          String?
  socialLinks           Json?
  interestingDetails    String?
  organizationName      String?
  providerId            String?
  provider              Provider?          @relation(fields: [providerId], references: [id], onDelete: SetNull)
  communitySlug         String             @default("denver")
  displayName           String             @default("Denver")
  city                  String             @default("Denver")
  region                String?
  state                 String?
  zip                   String?
  neighborhood          String             @default("")
  address               String             @default("")
  latitude              Float?
  longitude             Float?
  lunchIncluded         Boolean            @default(false)
  registrationOpenDate  DateTime?          @db.Date
  registrationOpenTime  String?
  registrationCloseDate DateTime?          @db.Date
  registrationStatus    RegistrationStatus @default(UNKNOWN)
  sourceType            SourceType         @default(CSV)
  sourceUrl             String?
  fieldSources          Json?
  lastVerifiedAt        DateTime?
  lastCrawledAt         DateTime?
  dataConfidence        DataConfidence     @default(PLACEHOLDER)
  archivedAt            DateTime?
  archivedBy            String?
  archiveReason         String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  ageGroups             CampAgeGroup[]
  schedules             CampSchedule[]
  pricing               CampPricing[]
  savedBy               SavedCamp[]
  notifications         Notification[]
  dataSourceCamps       DataSourceCamp[]
  reports               CampReport[]
  accreditations        CampAccreditation[]
  people                CampPersonRole[]

  @@index([category])
  @@index([campType])
  @@index([neighborhood])
  @@index([registrationStatus])
  @@index([city])
  @@index([communitySlug])
  @@index([providerId])
}

model CampAgeGroup {
  id       String @id @default(uuid())
  campId   String
  camp     Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)
  label    String
  minAge   Int?
  maxAge   Int?
  minGrade Int?
  maxGrade Int?

  @@index([campId])
}

model CampSchedule {
  id           String   @id @default(uuid())
  campId       String
  camp         Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  label        String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  startTime    String?
  endTime      String?
  earlyDropOff String?
  latePickup   String?

  @@index([campId])
}

model CampPricing {
  id            String      @id @default(uuid())
  campId        String
  camp          Camp        @relation(fields: [campId], references: [id], onDelete: Cascade)
  label         String
  amount        Decimal     @db.Decimal(10, 2)
  unit          PricingUnit
  durationWeeks Int?
  ageQualifier  String?
  discountNotes String?

  @@index([campId])
}

model Provider {
  id             String             @id @default(uuid())
  name           String
  slug           String             @unique
  websiteUrl     String?
  domain         String?
  logoUrl        String?
  address        String?
  city           String?
  neighborhood   String?
  contactEmail   String?
  contactPhone   String?
  applicationUrl String?
  socialLinks    Json?
  notes          String?
  crawlRootUrl   String?
  communitySlug  String             @default("denver")
  lastVerifiedAt DateTime?
  archivedAt     DateTime?
  archivedBy     String?
  archiveReason  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  camps          Camp[]
  people         ProviderPersonRole[]

  @@index([domain])
  @@index([communitySlug])
}

model User {
  id                     String              @id @default(uuid())
  email                  String              @unique
  name                   String              @default("")
  authProvider           AuthProvider        @default(EMAIL)
  tier                   UserTier            @default(FREE)
  stripeCustomerId       String?             @unique
  stripeSubscriptionId   String?
  notifyEmail            Boolean             @default(true)
  notifyPush             Boolean             @default(false)
  notifySms              Boolean             @default(false)
  phoneNumber            String?
  childAgeMin            Int?
  childAgeMax            Int?
  preferredNeighborhoods String[]            @default([])
  preferredCategories    CampCategory[]      @default([])
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  savedCamps             SavedCamp[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
}

model SavedCamp {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campId      String
  camp        Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  notes       String?
  notifyEmail Boolean  @default(true)
  notifyPush  Boolean  @default(false)
  notifySms   Boolean  @default(false)
  savedAt     DateTime @default(now())

  @@unique([userId, campId])
}

model Notification {
  id           String              @id @default(uuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  campId       String?
  camp         Camp?               @relation(fields: [campId], references: [id], onDelete: SetNull)
  type         NotificationType
  channel      NotificationChannel
  title        String
  body         String
  scheduledFor DateTime
  sentAt       DateTime?
  status       NotificationStatus  @default(PENDING)
  createdAt    DateTime            @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model DataSource {
  id           String           @id @default(uuid())
  name         String
  type         SourceType
  targetUrl    String           @default("")
  schedule     String?
  parserConfig Json?
  lastRunAt    DateTime?
  lastStatus   DataSourceStatus?
  campCount    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  camps        DataSourceCamp[]
}

model DataSourceCamp {
  id           String     @id @default(uuid())
  dataSourceId String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  campId       String
  camp         Camp       @relation(fields: [campId], references: [id], onDelete: Cascade)
  externalId   String?
  lastSyncedAt DateTime   @default(now())

  @@unique([dataSourceId, campId])
}

model CampReport {
  id         String   @id @default(uuid())
  campId     String
  camp       Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  userId     String?
  userEmail  String?
  type       String   @default("OTHER")
  description String
  status     String   @default("PENDING")
  adminNotes String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
}

model ReviewFlag {
  id         String           @id @default(uuid())
  entityType AdminEntityType
  entityId   String
  comment    String
  status     ReviewFlagStatus @default(OPEN)
  createdBy  String
  createdAt  DateTime         @default(now())
  resolvedBy String?
  resolvedAt DateTime?

  @@index([entityType, entityId])
}

model FieldAttestation {
  id                 String            @id @default(uuid())
  entityType         AdminEntityType
  entityId           String
  fieldKey           String
  valueSnapshot      Json?
  excerpt            String?
  sourceUrl          String?
  observedAt         DateTime          @default(now())
  approvedAt         DateTime?
  approvedBy         String?
  status             AttestationStatus @default(ACTIVE)
  lastRecheckedAt    DateTime?
  invalidatedAt      DateTime?
  invalidationReason String?
  notes              String?
  createdAt          DateTime          @default(now())

  @@index([entityType, entityId, fieldKey])
}

model AccreditationBody {
  id           String              @id @default(uuid())
  name         String
  slug         String              @unique
  websiteUrl   String?
  createdAt    DateTime            @default(now())
  accreditations CampAccreditation[]
}

model CampAccreditation {
  id             String   @id @default(uuid())
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  bodyId         String
  body           AccreditationBody @relation(fields: [bodyId], references: [id], onDelete: Cascade)
  status         String   @default("ACTIVE")
  scope          String?
  sourceUrl      String?
  excerpt        String?
  observedAt     DateTime @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  lastVerifiedAt DateTime?
  expiresAt      DateTime?
  notes          String?
  createdAt      DateTime @default(now())
}

model Person {
  id         String                @id @default(uuid())
  fullName   String
  slug       String                @unique
  bio        String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @default(now())
  contacts   PersonContactMethod[]
  campRoles  CampPersonRole[]
  providerRoles ProviderPersonRole[]
}

model PersonContactMethod {
  id        String   @id @default(uuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  type      String
  value     String
  label     String?
  createdAt DateTime @default(now())
}

model CampPersonRole {
  id         String   @id @default(uuid())
  campId     String
  camp       Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  personId   String
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  title      String?
  roleType   String   @default("CONTACT")
  notes      String?
  sourceUrl  String?
  excerpt    String?
  observedAt DateTime @default(now())
  approvedAt DateTime?
  approvedBy String?
  createdAt  DateTime @default(now())
}

model ProviderPersonRole {
  id         String   @id @default(uuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  personId   String
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  title      String?
  roleType   String   @default("CONTACT")
  notes      String?
  sourceUrl  String?
  excerpt    String?
  observedAt DateTime @default(now())
  approvedAt DateTime?
  approvedBy String?
  createdAt  DateTime @default(now())
}

model AiActionLog {
  id                   String             @id @default(uuid())
  capability           AiActionCapability
  action               String
  entityType           AdminEntityType?
  entityId             String?
  status               AiActionStatus     @default(REQUESTED)
  requestedBy          String
  confirmedBy          String?
  requiresConfirmation Boolean            @default(true)
  input                Json?
  output               Json?
  error                String?
  createdAt            DateTime           @default(now())
  completedAt          DateTime?

  @@index([entityType, entityId])
}
