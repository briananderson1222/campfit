ADMIN_EMAILS="admin@example.com"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Optional alternative to the PG* fields below for local tooling
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"
PGHOST="your-db-host"
PGPORT="6543"
PGDATABASE="postgres"
PGUSER="your-db-user"
PGPASSWORD="your-db-password"
ANTHROPIC_API_KEY=""
# Traverse parity (npm run traverse:parity) resolves its provider via
# @kontourai/datum (.datum/config.json); the default extraction-default role
# points at Z.AI, so set ZAI_API_KEY (or switch the role to use ANTHROPIC_API_KEY above).
ZAI_API_KEY=""
GEMINI_API_KEY=""
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CampFit <notifications@example.com>"
CRON_SECRET="replace-me"

# Optional read-only production smoke test settings
PROD_SMOKE_BASE_URL="https://camp.fit"
PROD_SMOKE_ADMIN_REVIEW_PATH="/admin/review/survey-fixture"
PLAYWRIGHT_ADMIN_EMAIL="admin-smoke@example.com"
PLAYWRIGHT_ADMIN_PASSWORD="replace-me"
